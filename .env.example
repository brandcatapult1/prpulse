# Cloud deployment — set these in Render dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SESSION_SECRET=generate-a-long-random-string
APP_URL=https://prpulse-1.onrender.com
# Google OAuth — add when ready for production (dev mode works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Cloudinary — proof screenshot uploads (server-side only; never expose API secret to the client)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Upload folder prefix on the shared Cloudinary account (default dev — set prod in production)
CLOUDINARY_FOLDER=dev
# Set to false to require Google even when credentials are missing
DEV_AUTH=true
