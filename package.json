{
  "name": "pr-pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PR Pulse — Relationship Operations Platform for Brand Catapult",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "db:migrate": "node scripts/migrate.mjs up",
    "db:migrate:down": "node scripts/migrate.mjs down",
    "db:migrate:status": "node scripts/migrate.mjs status",
    "db:test": "node db/tests/integrity.test.mjs && node db/tests/permissions.test.mjs && node db/tests/mobile-dedup.test.mjs && node db/tests/contact-patch.test.mjs && node db/tests/contact-batch.test.mjs && node db/tests/campaign-tags.test.mjs",
    "db:test:mobile": "node db/tests/mobile-dedup.test.mjs",
    "db:test:permissions": "node db/tests/permissions.test.mjs",
    "db:test:contacts": "node db/tests/contact-patch.test.mjs",
    "db:test:batch": "node db/tests/contact-batch.test.mjs",
    "db:test:campaign-tags": "node db/tests/campaign-tags.test.mjs",
    "db:seed:demo": "node scripts/seed-demo.mjs",
    "db:seed:demo:reset": "node scripts/seed-demo.mjs --reset",
    "db:seed:demo:repair": "node scripts/seed-demo.mjs --repair",
    "build": "npm run build --workspace=web",
    "start": "node server/src/index.mjs",
    "dev": "npm run dev --workspace=web",
    "render-build": "npm install && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cloudinary": "^2.6.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.1"
  }
}
